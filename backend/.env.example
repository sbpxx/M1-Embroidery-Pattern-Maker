# Copier ce fichier en .env et remplir les valeurs

# Clé secrète pour les tokens JWT
JWT_SECRET=change-me-with-a-long-random-string

# Azure Computer Vision (optionnel — nécessaire pour la page Import)
VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
VISION_KEY=your-azure-vision-api-key
